# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database PostgreSQL (gunakan salah satu: DATABASE_URL atau DB_*)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/db_bgg_group
DB_HOST=localhost
DB_PORT=5432
DB_NAME=db_bgg_group
DB_USERNAME=postgres
DB_PASSWORD=YOUR_PASSWORD
DB_DIALECT=postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS — satu URL atau beberapa dipisah koma (subdomain dev, staging, dll.)
CORS_ORIGIN=http://localhost:3000

# Database sync: set SYNC_ALTER=true hanya jika perlu ALTER tabel (hati-hati jika ada view)
# SYNC_ALTER=true

# Upload (file disimpan di project root /uploads)
MAX_FILE_SIZE=5242880

# Email / SMTP (notifikasi transaksi: invoice, pembayaran, refund, trip selesai)
# Cara isi:
#   SMTP_USER    = email pengirim (contoh: noreply@gmail.com)
#   SMTP_PASSWORD = password email. Gmail: wajib pakai Sandi Aplikasi (bukan password login).
#   EMAIL_FROM   = (opsional) kosongkan = pakai SMTP_USER. Isi jika ingin alamat "dari" lain.
#   EMAIL_FROM_NAME = nama yang tampil di inbox penerima
# Gmail: Akun Google > Keamanan > Verifikasi 2 langkah (aktifkan) > Sandi Aplikasi > buat untuk "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@contoh.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_SECURE=false
EMAIL_FROM=
EMAIL_FROM_NAME=Bintang Global - Admin Pusat

# RATE_LIMIT_WINDOW=15
# RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=info

# Webhook Deployment (jika menggunakan webhook server, bukan GitHub Actions)
# WEBHOOK_PORT=9000
# WEBHOOK_SECRET=your-webhook-secret-here

# AI Chat (Asisten AI untuk Owner: jawab pertanyaan, nego harga, isi draft order)
# Dapatkan API key di https://platform.openai.com/api-keys
# Tanpa OPENAI_API_KEY, fitur Asisten AI menampilkan pesan agar owner buat order manual dari menu.
OPENAI_API_KEY=sk-...
# Opsional: model (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
