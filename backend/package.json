{
  "name": "bintang-global-backend",
  "version": "1.0.0",
  "description": "Backend API for Bintang Global Group",
  "main": "src/server.js",
  "scripts": {
    "start": "npm run migrate && node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "seed": "sequelize-cli db:seed:all",
    "seed:undo": "sequelize-cli db:seed:undo:all",
    "seed:branches": "sequelize-cli db:seed --seed 20250217000000-branches-indonesia.js",
    "seed:branches:undo": "sequelize-cli db:seed:undo --seed 20250217000000-branches-indonesia.js",
    "seed:accounting": "sequelize-cli db:seed --seed 20250217000010-accounting-defaults.js",
    "seed:accounting:undo": "sequelize-cli db:seed:undo --seed 20250217000010-accounting-defaults.js",
    "seed:banks": "sequelize-cli db:seed --seed 20260301000001-master-banks.js",
    "seed:banks:undo": "sequelize-cli db:seed:undo --seed 20260301000001-master-banks.js",
    "seed:kabupaten": "sequelize-cli db:seed --seed 20260305000001-seed-kabupaten-master.js",
    "seed:kabupaten:undo": "sequelize-cli db:seed:undo --seed 20260305000001-seed-kabupaten-master.js",
    "sync:location": "node scripts/sync-location-from-master.js",
    "sync:wilayah": "node scripts/sync-wilayah-provinsi-branch.js",
    "seed:workflow-koordinator": "node scripts/seed-workflow-koordinator-users.js",
    "set-passwords": "node scripts/set-all-passwords.js",
    "db:create": "sequelize-cli db:create",
    "db:drop": "sequelize-cli db:drop",
    "db:update": "npm run migrate && node scripts/sync-database.js && npm run seed && npm run seed:workflow-koordinator",
    "db:recreate": "node scripts/recreate-database.js && npm run db:update",
    "db:sync": "node scripts/sync-database.js",
    "clean:uploads": "node scripts/clean-uploads.js",
    "clean:data-keep-master": "node scripts/clean-data-keep-master-only.js",
    "clean:data-keep-users-banks-wilayah": "node scripts/clean-data-keep-users-banks-wilayah.js",
    "clear:orders-invoices": "node scripts/clear-orders-invoices.js",
    "clear:orders-invoices-owners": "node scripts/clear-orders-and-owner-accounts.js",
    "ensure:owner-manual-columns": "node scripts/ensure-invoice-order-owner-manual-columns.js",
    "ensure:hotel-monthly-component": "node scripts/ensure-hotel-monthly-component-column.js",
    "ensure:refunds-payout-sender": "node scripts/ensure-refunds-payout-sender-columns.js",
    "backfill:hotel-monthly": "node scripts/backfill-hotel-monthly-from-prices.js",
    "generate:payment-proofs": "node scripts/generate-payment-proof-examples.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "archiver": "^7.0.1",
    "express-async-handler": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "fuse.js": "^7.1.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.45",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.15",
    "openai": "^4.28.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.3",
    "sharp": "^0.33.5",
    "socket.io": "^4.7.5",
    "validator": "^13.12.0",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0"
  }
}
